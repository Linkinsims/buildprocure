generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  PROJECT_MANAGER
  QUANTITY_SURVEYOR
  SITE_MANAGER
  SUBCONTRACTOR
}

enum PricingTier {
  STARTER
  GROWTH
  ENTERPRISE
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum RfqStatus {
  DRAFT
  SENT
  QUOTES_RECEIVED
  AWARDED
  CANCELLED
}

enum QuoteStatus {
  PENDING
  SUBMITTED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum PoStatus {
  DRAFT
  SENT
  ACKNOWLEDGED
  PARTIALLY_DELIVERED
  FULLY_DELIVERED
  CLOSED
  CANCELLED
}

enum DeliveryStatus {
  PENDING
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  SHORT_DELIVERY
  DAMAGED
  REJECTED
}

enum ContractorStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  SUSPENDED
}

enum DocumentType {
  TAX_CLEARANCE
  BEE_CERTIFICATE
  PUBLIC_LIABILITY
  CIDB_REGISTRATION
  CIDB_GRADING
  INSURANCE
  OTHER
}

enum AlertType {
  DOCUMENT_EXPIRY
  CIDB_GRADE_MISMATCH
  BUDGET_VARIANCE
  DELIVERY_OVERDUE
  LOW_STOCK
  PAYMENT_TERMS
}

model Organisation {
  id          String      @id @default(cuid())
  name        String
  email       String      @unique
  phone       String?
  address     String?
  city        String?
  logo        String?
  tier        PricingTier @default(STARTER)
  trialEndsAt DateTime?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  users       User[]
  projects    Project[]
  suppliers   Supplier[]
  contractors Contractor[]
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  password       String?
  name           String
  phone          String?
  avatar         String?
  role           UserRole  @default(PROJECT_MANAGER)
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  projects      ProjectUser[]
  activities    Activity[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id             String        @id @default(cuid())
  name           String
  description    String?
  code           String        @unique
  status         ProjectStatus @default(PLANNING)
  organisationId String
  organisation   Organisation  @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  
  startDate      DateTime?
  endDate        DateTime?
  estimatedValue Decimal       @default(0) @db.Decimal(15, 2)
  actualValue    Decimal       @default(0) @db.Decimal(15, 2)
  
  cidbGrade      Int?
  location       String?
  city           String?
  address        String?
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  users          ProjectUser[]
  budgets        Budget[]
  rfqs           Rfq[]
  purchaseOrders PurchaseOrder[]
  deliveries     Delivery[]
  inventories    Inventory[]
  activities     Activity[]
  costCodes      CostCode[]
}

model ProjectUser {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("team_member")

  @@unique([projectId, userId])
}

model CostCode {
  id        String   @id @default(cuid())
  code      String
  name      String
  category  String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  budget    Decimal  @default(0) @db.Decimal(15, 2)
  committed Decimal  @default(0) @db.Decimal(15, 2)
  actual    Decimal  @default(0) @db.Decimal(15, 2)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, code])
}

model Budget {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  totalBudget Decimal  @default(0) @db.Decimal(15, 2)
  committed   Decimal  @default(0) @db.Decimal(15, 2)
  actual      Decimal  @default(0) @db.Decimal(15, 2)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId])
}

model Supplier {
  id             String      @id @default(cuid())
  name           String
  email          String
  phone          String?
  address        String?
  city           String?
  vatRegistered  Boolean     @default(false)
  vatNumber      String?
  contactPerson  String?
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  
  rating         Int         @default(0)
  totalOrders    Int         @default(0)
  onTimeDelivery Int         @default(0)
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  rfqQuotes      RfqQuote[]
  purchaseOrders PurchaseOrder[]
}

model Rfq {
  id          String     @id @default(cuid())
  rfqNumber   String     @unique
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  title       String
  description String?
  category    String
  status      RfqStatus  @default(DRAFT)
  
  requiredBy  DateTime?
  deliveryAddress String?
  notes       String?
  
  awardedToId String?
  awardedTo   Supplier?  @relation(fields: [awardedToId], references: [id])
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  items       RfqItem[]
  quotes      RfqQuote[]
}

model RfqItem {
  id        String   @id @default(cuid())
  rfqId     String
  rfq       Rfq      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  
  description String
  unit       String
  quantity   Decimal  @db.Decimal(15, 2)
  specs      String?
  
  createdAt DateTime @default(now())
}

model RfqQuote {
  id          String      @id @default(cuid())
  rfqId       String
  rfq         Rfq        @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  supplierId  String
  supplier    Supplier   @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  
  status      QuoteStatus @default(PENDING)
  totalAmount Decimal     @db.Decimal(15, 2)
  leadTime    String?
  paymentTerms String?
  notes       String?
  
  submittedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  items       RfqQuoteItem[]
}

model RfqQuoteItem {
  id          String     @id @default(cuid())
  quoteId     String
  quote       RfqQuote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  rfqItemId   String
  rfqItem     RfqItem   @relation(fields: [rfqItemId], references: [id])
  
  unitPrice   Decimal    @db.Decimal(15, 2)
  totalPrice  Decimal    @db.Decimal(15, 2)
  
  createdAt   DateTime   @default(now())
}

model PurchaseOrder {
  id              String       @id @default(cuid())
  poNumber        String       @unique
  projectId      String
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  supplierId      String
  supplier        Supplier     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  
  rfqId           String?
  rfq             Rfq?         @relation(fields: [rfqId], references: [id])
  
  status          PoStatus     @default(DRAFT)
  orderDate       DateTime     @default(now())
  deliveryDate    DateTime?
  requiredDate    DateTime?
  
  deliveryAddress String?
  billingAddress  String?
  paymentTerms    String?
  notes           String?
  
  subtotal        Decimal      @default(0) @db.Decimal(15, 2)
  vatAmount       Decimal      @default(0) @db.Decimal(15, 2)
  totalAmount     Decimal      @default(0) @db.Decimal(15, 2)
  
  acknowledgedAt  DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  items           PoItem[]
  deliveries      Delivery[]
}

model PoItem {
  id              String         @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  
  description     String
  unit            String
  quantity        Decimal        @db.Decimal(15, 2)
  unitPrice       Decimal        @db.Decimal(15, 2)
  totalPrice      Decimal        @db.Decimal(15, 2)
  
  quantityReceived Decimal      @default(0) @db.Decimal(15, 2)
  
  createdAt       DateTime       @default(now())
}

model Delivery {
  id              String        @id @default(cuid())
  deliveryNumber  String        @unique
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  expectedDate    DateTime?
  actualDate      DateTime?
  status          DeliveryStatus @default(PENDING)
  
  deliveryNoteNumber String?
  receivingSignature String?
  conditionNotes   String?
  
  isLate          Boolean        @default(false)
  isShortDelivery Boolean        @default(false)
  isDamaged       Boolean        @default(false)
  
  receivedBy      String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  items           DeliveryItem[]
}

model DeliveryItem {
  id          String   @id @default(cuid())
  deliveryId  String
  delivery    Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  poItemId    String
  poItem      PoItem   @relation(fields: [poItemId], references: [id])
  
  quantityReceived Decimal @db.Decimal(15, 2)
  condition       String?
  notes           String?
  
  createdAt   DateTime @default(now())
}

model Contractor {
  id             String          @id @default(cuid())
  companyName    String
  email          String
  phone          String?
  address        String?
  city           String?
  
  cidbGrade      Int?
  cidbExpiry    DateTime?
  cidbNumber    String?
  
  taxClearanceExpiry DateTime?
  beeCertificateExpiry DateTime?
  beeLevel       String?
  
  publicLiabilityExpiry DateTime?
  publicLiabilityValue Decimal @default(0) @db.Decimal(15, 2)
  
  status         ContractorStatus @default(ACTIVE)
  rating         Int            @default(0)
  
  organisationId String
  organisation   Organisation    @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  projects       ContractorProject[]
  contracts      ContractorContract[]
  documents      ContractorDocument[]
  performanceRatings ContractorRating[]
}

model ContractorProject {
  id           String     @id @default(cuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  projectId    String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  contractValue Decimal   @default(0) @db.Decimal(15, 2)
  status        String    @default("active")
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([contractorId, projectId])
}

model ContractorContract {
  id            String   @id @default(cuid())
  contractorId  String
  contractor    Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  
  contractNumber String
  description   String
  value         Decimal  @default(0) @db.Decimal(15, 2)
  startDate     DateTime
  endDate       DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ContractorDocument {
  id            String      @id @default(cuid())
  contractorId  String
  contractor    Contractor  @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  
  type          DocumentType
  documentName  String
  fileUrl       String?
  expiryDate    DateTime?
  isVerified    Boolean     @default(false)
  verifiedAt    DateTime?
  notes         String?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ContractorRating {
  id           String     @id @default(cuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  qualityRating Int      @default(0)
  timeRating    Int      @default(0)
  safetyRating  Int      @default(0)
  communicationRating Int @default(0)
  overallRating Int      @default(0)
  comments     String?
  ratedBy      String?
  
  createdAt    DateTime   @default(now())
}

model Inventory {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  materialName String
  unit         String
  category     String
  
  received     Decimal  @default(0) @db.Decimal(15, 2)
  issued       Decimal  @default(0) @db.Decimal(15, 2)
  consumed     Decimal  @default(0) @db.Decimal(15, 2)
  wastage      Decimal  @default(0) @db.Decimal(15, 2)
  balance      Decimal  @default(0) @db.Decimal(15, 2)
  
  minLevel     Decimal  @default(0) @db.Decimal(15, 2)
  
  lastReceiptDate DateTime?
  lastIssueDate    DateTime?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model InventoryTransaction {
  id          String   @id @default(cuid())
  inventoryId String
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  
  type        String
  quantity    Decimal  @db.Decimal(15, 2)
  reference   String?
  costCode    String?
  workPackage String?
  notes       String?
  
  createdAt   DateTime @default(now())
}

model Alert {
  id          String     @id @default(cuid())
  type        AlertType
  title       String
  message     String
  
  entityType  String
  entityId    String
  
  organisationId String
  projectId   String?
  isRead      Boolean    @default(false)
  isResolved  Boolean    @default(false)
  
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
}

model Activity {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String
  description String
  
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}

model DemoRequest {
  id          String   @id @default(cuid())
  companyName String
  contactName String
  email       String
  phone       String?
  message     String?
  status      String   @default("pending")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}